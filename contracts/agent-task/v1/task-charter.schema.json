{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-charter/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_id", "task_id", "charter_version", "previous_charter_ref",
    "objective_restated", "scope_in", "scope_out", "assumptions", "plan",
    "requirement_ids", "unresolved_questions", "delivery_plan", "created_by",
    "created_at", "digest"
  ],
  "properties": {
    "schema_id": {"const": "task-charter/v1"},
    "task_id": {"type": "string", "pattern": "^task_[0-9a-f]{32}$"},
    "charter_version": {"type": "integer", "minimum": 1, "maximum": 9007199254740991},
    "previous_charter_ref": {"oneOf": [{"$ref": "content-ref/v1"}, {"type": "null"}]},
    "objective_restated": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 16384},
    "scope_in": {
      "type": "array", "maxItems": 256, "uniqueItems": true,
      "x-pullwise-sorted-unique": true,
      "items": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 4096}
    },
    "scope_out": {
      "type": "array", "maxItems": 256, "uniqueItems": true,
      "x-pullwise-sorted-unique": true,
      "items": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 4096}
    },
    "assumptions": {
      "type": "array", "maxItems": 256,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["statement", "impact", "reversible"],
        "properties": {
          "statement": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 16384},
          "impact": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 4096},
          "reversible": {"type": "boolean"}
        }
      }
    },
    "plan": {
      "type": "array", "minItems": 1, "maxItems": 256,
      "items": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 4096}
    },
    "requirement_ids": {
      "type": "array", "minItems": 1, "maxItems": 512, "uniqueItems": true,
      "x-pullwise-sorted-unique": true,
      "items": {"type": "string", "pattern": "^req_[a-z_]+_[0-9a-f]{64}$"}
    },
    "unresolved_questions": {
      "type": "array", "maxItems": 256,
      "items": {"type": "string", "minLength": 1, "x-pullwise-max-utf8-bytes": 4096}
    },
    "delivery_plan": {
      "type": "object", "additionalProperties": false,
      "required": ["kind", "required_outputs", "output_language"],
      "properties": {
        "kind": {"type": "string", "minLength": 1, "maxLength": 80},
        "required_outputs": {
          "type": "array", "maxItems": 64, "uniqueItems": true,
          "x-pullwise-sorted-unique": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 160}
        },
        "output_language": {"type": "string", "minLength": 1, "maxLength": 35}
      }
    },
    "created_by": {"$ref": "actor/v1"},
    "created_at": {"type": "string", "format": "utc-rfc3339-ms"},
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
