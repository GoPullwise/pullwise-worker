{
  "mode": "standard",
  "codegraph": {
    "command": "codegraph",
    "optional_sync": true
  },
  "codex": {
    "command": "codex",
    "reasoning_effort": "high"
  },
  "finders": {
    "enabled": true,
    "max_workers": 4
  },
  "scoring": {
    "always_repro_severities": [
      "critical",
      "high"
    ],
    "min_score_for_repro": 8
  },
  "repro": {
    "enabled": true,
    "max_repro": 0,
    "max_workers": 2,
    "require_red_green": false
  }
}
